diff --git a/fs/Makefile b/fs/Makefile
index 0000000..1111111 100644
--- a/fs/Makefile
+++ b/fs/Makefile
@@ -999,3 +999,7 @@ obj-$(CONFIG_FSNOTIFY)      += fsnotify/
 obj-$(CONFIG_EXPORTFS)      += exportfs/
 obj-$(CONFIG_OVERLAY_FS)    += overlayfs/
 
+# SUSFS support
+obj-$(CONFIG_SUSFS) += susfs.o
+
diff --git a/include/linux/mount.h b/include/linux/mount.h
index 0000000..1111111 100644
--- a/include/linux/mount.h
+++ b/include/linux/mount.h
@@ -1,6 +1,7 @@
 struct mount {
     struct hlist_node mnt_hash;
     struct mount *mnt_parent;
+    
     struct dentry *mnt_mountpoint;
     struct vfsmount mnt;
     union {
@@ -150,6 +151,11 @@ struct mount {
     struct list_head mnt_mounts;
     struct list_head mnt_child;
 
+#ifdef CONFIG_SUSFS
+    unsigned long susfs_flags;
+#endif
+
 };
 
diff --git a/fs/namespace.c b/fs/namespace.c
index 0000000..1111111 100644
--- a/fs/namespace.c
+++ b/fs/namespace.c
@@ -20,6 +20,7 @@
 #include <linux/sched/task.h>
 #include <linux/mount.h>
 #include <linux/fs_struct.h>
+#include <linux/susfs.h>
 
@@ -940,6 +941,11 @@ struct vfsmount *vfs_kern_mount(struct file_system_type *type,
     if (!mnt)
         return ERR_PTR(-ENOMEM);
 
+#ifdef CONFIG_SUSFS
+    susfs_mnt_init(&mnt->mnt);
+#endif
+
     mnt->mnt.mnt_sb = sb;
     mnt->mnt.mnt_root = root;
 
@@ -970,6 +976,11 @@ struct vfsmount *vfs_kern_mount(struct file_system_type *type,
     list_add_tail(&mnt->mnt_instance, &sb->s_mounts);
     unlock_mount_hash();
 
+#ifdef CONFIG_SUSFS
+    susfs_register_mount(mnt);
+#endif
+
     return &mnt->mnt;
 }
